   "source": [
    "# Program to Calculate Compound Interest\n",
    "\n",
    "p = float(input(\"Enter the amount for principal: \"))\n",
    "r = float(input(\"Enter the interest rate: \"))\n",
    "t = float(input(\"Enter the number of years: \"))\n",
    "\n",
    "\n",
    "\n",
    "a = p * (1 + (r*t)/100) \n",
    "\n",
    "print(\"The compound amount is = N\", a)\n"
   ]
  },
